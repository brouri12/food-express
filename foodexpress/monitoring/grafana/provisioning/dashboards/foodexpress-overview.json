{
  "title": "FoodExpress — Micro-services Overview",
  "uid": "foodexpress-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Services UP",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "count(up{job=~\".*-service|api-gateway|eureka-server\"} == 1)",
        "legendFormat": "UP"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":1}] }}}
    },
    {
      "id": 2, "type": "stat", "title": "HTTP Requests/s (Gateway)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"api-gateway\"}[1m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 3, "type": "stat", "title": "Avg Response Time (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "avg(rate(http_server_requests_seconds_sum[1m]) / rate(http_server_requests_seconds_count[1m])) * 1000",
        "legendFormat": "ms"
      }]
    },
    {
      "id": 4, "type": "stat", "title": "JVM Heap Used",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / 1024 / 1024",
        "legendFormat": "MB"
      }]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Requests par service",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (job) (rate(http_server_requests_seconds_count[1m]))",
        "legendFormat": "{{job}}"
      }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Erreurs HTTP (5xx)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
        "legendFormat": "{{job}} errors"
      }]
    },
    {
      "id": 7, "type": "gauge", "title": "CPU Usage par service",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [{
        "expr": "process_cpu_usage * 100",
        "legendFormat": "{{job}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":60},{"color":"red","value":85}] }}}
    }
  ]
}
